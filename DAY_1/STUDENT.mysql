SHOW DATABASES;

CREATE DATABASE AIDS;

USE AIDS;

CREATE TABLE STUDENT(
ID INT,
NAME VARCHAR(30),
GPA DECIMAL(3,2));
DESCRIBE STUDENT;

ALTER TABLE STUDENT ADD DEPT VARCHAR(30);

ALTER TABLE STUDENT DROP DEPT ;

